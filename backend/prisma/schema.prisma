generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  candidate
}

enum Difficulty {
  easy
  medium
  hard
}

enum AssessmentStatus {
  not_started
  in_progress
  completed
  expired
}

enum SubmissionStatus {
  pending
  running
  completed
  error
}

enum TestCaseStatus {
  passed
  failed
  error
  timeout
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  fullName        String   @map("full_name")
  enrollmentNo    String?  @unique @map("enrollment_no")
  role            UserRole
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  lastLogin       DateTime? @map("last_login")
  isActive        Boolean  @default(true) @map("is_active")

  // Relations
  createdQuestions    Question[]
  createdAssessments  Assessment[]
  userAssessments     UserAssessment[]
  practiceSubmissions Submission[]   @relation("PracticeSubmissions")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Question {
  id              String     @id @default(uuid())
  title           String
  description     String     @db.Text
  difficulty      Difficulty
  timeLimit       Int        @map("time_limit") // seconds
  memoryLimit     Int        @map("memory_limit") // MB
  constraints     String?    @db.Text
  inputFormat     String?    @map("input_format") @db.Text
  outputFormat    String?    @map("output_format") @db.Text
  sampleInput     String?    @map("sample_input") @db.Text
  sampleOutput    String?    @map("sample_output") @db.Text
  explanation     String?    @db.Text
  tags            String[]
  starterCodePython     String?  @map("starter_code_python") @db.Text
  starterCodeJavascript String?  @map("starter_code_javascript") @db.Text
  starterCodeJava       String?  @map("starter_code_java") @db.Text
  starterCodeCpp        String?  @map("starter_code_cpp") @db.Text
  starterCodeC          String?  @map("starter_code_c") @db.Text
  createdById     String     @map("created_by")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  isActive        Boolean    @default(true) @map("is_active")

  // Relations
  createdBy            User                   @relation(fields: [createdById], references: [id])
  testCases            TestCase[]
  assessmentQuestions  AssessmentQuestion[]
  submissions          Submission[]

  @@index([difficulty])
  @@index([createdById])
  @@map("questions")
}

model TestCase {
  id              String   @id @default(uuid())
  questionId      String   @map("question_id")
  input           String   @db.Text
  expectedOutput  String   @map("expected_output") @db.Text
  isHidden        Boolean  @default(false) @map("is_hidden")
  points          Int      @default(10)
  orderIndex      Int      @map("order_index")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  question          Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  submissionResults SubmissionResult[]

  @@index([questionId])
  @@map("test_cases")
}

model Assessment {
  id              String    @id @default(uuid())
  title           String
  description     String?   @db.Text
  duration        Int       // minutes
  passingScore    Int       @default(0) @map("passing_score")
  totalScore      Int?      @map("total_score")
  startTime       DateTime? @map("start_time")
  endTime         DateTime? @map("end_time")
  instructions    String?   @db.Text
  allowedLanguages String[] @map("allowed_languages")
  createdById     String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  isActive        Boolean   @default(true) @map("is_active")

  // Relations
  createdBy            User                   @relation(fields: [createdById], references: [id])
  assessmentQuestions  AssessmentQuestion[]
  userAssessments      UserAssessment[]

  @@index([createdById])
  @@index([startTime, endTime])
  @@map("assessments")
}

model AssessmentQuestion {
  id            String   @id @default(uuid())
  assessmentId  String   @map("assessment_id")
  questionId    String   @map("question_id")
  points        Int      @default(100)
  orderIndex    Int      @map("order_index")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@map("assessment_questions")
}

model UserAssessment {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  assessmentId  String           @map("assessment_id")
  status        AssessmentStatus @default(not_started)
  startedAt     DateTime?        @map("started_at")
  completedAt   DateTime?        @map("completed_at")
  score         Int              @default(0)
  maxScore      Int?             @map("max_score")
  timeTaken     Int?             @map("time_taken") // seconds
  tabSwitches   Int              @default(0) @map("tab_switches")
  createdAt     DateTime         @default(now()) @map("created_at")

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment  Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@unique([userId, assessmentId])
  @@index([userId])
  @@index([assessmentId])
  @@index([status])
  @@map("user_assessments")
}

model Submission {
  id               String           @id @default(uuid())
  userAssessmentId String?          @map("user_assessment_id")
  practiceUserId   String?          @map("practice_user_id")
  questionId       String           @map("question_id")
  language         String
  code             String           @db.Text
  status           SubmissionStatus @default(pending)
  executionTime    Int?             @map("execution_time") // milliseconds
  memoryUsed       Int?             @map("memory_used") // KB
  score            Int              @default(0)
  maxScore         Int?             @map("max_score")
  passedTests      Int              @default(0) @map("passed_tests")
  totalTests       Int?             @map("total_tests")
  errorMessage     String?          @map("error_message") @db.Text
  submittedAt      DateTime         @default(now()) @map("submitted_at")
  evaluatedAt      DateTime?        @map("evaluated_at")

  // Relations
  userAssessment    UserAssessment?    @relation(fields: [userAssessmentId], references: [id], onDelete: Cascade)
  practiceUser      User?              @relation("PracticeSubmissions", fields: [practiceUserId], references: [id], onDelete: Cascade)
  question          Question           @relation(fields: [questionId], references: [id])
  submissionResults SubmissionResult[]

  @@index([userAssessmentId])
  @@index([practiceUserId])
  @@index([questionId])
  @@index([status])
  @@map("submissions")
}

model SubmissionResult {
  id            String         @id @default(uuid())
  submissionId  String         @map("submission_id")
  testCaseId    String         @map("test_case_id")
  status        TestCaseStatus
  actualOutput  String?        @map("actual_output") @db.Text
  executionTime Int?           @map("execution_time") // milliseconds
  memoryUsed    Int?           @map("memory_used") // KB
  errorMessage  String?        @map("error_message") @db.Text
  pointsEarned  Int            @default(0) @map("points_earned")
  createdAt     DateTime       @default(now()) @map("created_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCase   TestCase   @relation(fields: [testCaseId], references: [id])

  @@index([submissionId])
  @@map("submission_results")
}
